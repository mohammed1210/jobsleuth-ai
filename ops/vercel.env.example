# Root directory: frontend

NEXT_PUBLIC_BACKEND_URL=https://your-railway-backend.up.railway.app
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_KEY=your_supabase_anon_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_pro_xxx
NEXT_PUBLIC_STRIPE_PRICE_CAREER_PLUS=price_career_plus_xxx
NEXT_PUBLIC_SITE_URL=https://your-vercel-app.vercel.app
