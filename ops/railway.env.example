# Railway backend environment variables
# Configure these in Railway Variables for the backend service.
# Root directory: backend

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
OPENAI_API_KEY=
FRONTEND_URL=https://your-vercel-app.vercel.app
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,https://your-preview-domain.vercel.app
ENABLE_DEBUG_ROUTES=0
EMAIL_SERVER=
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@jobsleuth.ai
PROVIDER_API_KEY=
SCRAPE_PROVIDER=off
FEATURE_SCRAPE_INTERNAL=false
AUTH_SCRAPER_KEY=replace_with_long_random_value
